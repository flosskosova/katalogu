# Production secrets exported from Vercel / Supabase — never commit this file.
# Used by: npm run export:production-db
#
# Minimum keys:
#   DATABASE_URL_PRODUCTION=postgres://...@aws-0-....pooler.supabase.com:5432/postgres
#   PAYLOAD_SECRET=...
#   PREVIEW_SECRET=...
#
# Copy the same PAYLOAD_SECRET and PREVIEW_SECRET into the VPS `.env` (from .env.docker.example).
