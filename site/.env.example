# Public site URL for SEO metadata, sitemap, and robots (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Same origin as the app (Payload admin + APIs). No trailing slash.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Payload — generate a long random string in production
PAYLOAD_SECRET=replace-with-long-random-secret

# SQLite — local file (default) or remote libSQL (required on Vercel + /admin)
# Local:
# DATABASE_URL=file:./data/payload.sqlite
#
# Turso (recommended names per https://docs.turso.tech/integrations/vercel ):
# TURSO_DATABASE_URL=libsql://your-db-name-yourorg.turso.io
# TURSO_AUTH_TOKEN=eyJ...
# Alternative names (also supported):
# DATABASE_URL=libsql://...
# DATABASE_AUTH_TOKEN=eyJ...
# Use one pair only. Do not wrap values in quotes in the Vercel UI. Enable Production (and Preview if needed).

# Draft preview: same value used in /api/draft?secret=
PREVIEW_SECRET=replace-with-preview-secret

# Force static seed data (skip CMS reads)
# USE_STATIC_CATALOG=false

# When CMS has zero tools, fall back to static data (default true). Set false to show empty.
# CMS_FALLBACK_STATIC=true

# When CMS has tools, merge in static `data/tools.ts` (SourceForge + opensource seeds, etc.).
# CMS entries override the same slug. Set false for a CMS-only catalog.
# CMS_MERGE_STATIC_TOOLS=true

# After creating `.env`, run once: npm run seed:catalog (loads this file via Node --env-file)
# Optional: first admin for `npm run seed:catalog`
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=changeme
