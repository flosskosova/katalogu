{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "functions": {
    "app/api/suggest-tool/route.ts": {
      "maxDuration": 60
    },
    "app/(payload)/api/[...slug]/route.ts": {
      "maxDuration": 300
    },
    "app/(payload)/admin/[[...segments]]/page.tsx": {
      "maxDuration": 300
    }
  }
}
