# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Payload CMS (local SQLite + uploads)
/data/payload.sqlite
/data/payload.sqlite-*
/media/
/temp-payload/

# vercel
.vercel
# One-line Postgres URL for `npm run vercel:push-database-url` (never commit)
dburl.secret.txt

# typescript
*.tsbuildinfo
next-env.d.ts

# local fetch cache (backfill whyIncluded)
/scripts/.why-included-cache.json
