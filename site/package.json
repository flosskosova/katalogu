{
  "name": "site",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-2.0",
  "scripts": {
    "postinstall": "node ./scripts/ensure-libsql-web-driver.mjs && patch-package",
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "build": "node ./scripts/generate-favicons.mjs && next build",
    "start": "next start",
    "lint": "eslint .",
    "validate:tool-slugs": "node ./node_modules/jiti/lib/jiti-cli.mjs scripts/validate-tool-slugs.ts",
    "seed:catalog": "node --env-file=.env ./node_modules/jiti/lib/jiti-cli.mjs scripts/seed-catalog.ts",
    "verify:catalog-sync": "node --env-file=.env ./node_modules/jiti/lib/jiti-cli.mjs scripts/verify-catalog-sync.ts",
    "catalog:sync": "npm run validate:tool-slugs && npm run seed:catalog && npm run verify:catalog-sync",
    "backfill:seo": "node --env-file=.env ./node_modules/jiti/lib/jiti-cli.mjs scripts/backfill-tool-seo.ts",
    "backfill:seo:categories": "node --env-file=.env ./node_modules/jiti/lib/jiti-cli.mjs scripts/backfill-category-seo.ts",
    "backfill:why-included": "node ./node_modules/jiti/lib/jiti-cli.mjs scripts/backfill-why-included-official-sites.ts",
    "payload:migrate:create": "node --env-file=.env ./node_modules/jiti/lib/jiti-cli.mjs scripts/payload-migrate.ts create",
    "payload:migrate": "node --env-file=.env ./node_modules/jiti/lib/jiti-cli.mjs scripts/payload-migrate.ts run",
    "payload:migrate:status": "node --env-file=.env ./node_modules/jiti/lib/jiti-cli.mjs scripts/payload-migrate.ts status",
    "admin:reset-password": "node --env-file=.env ./node_modules/jiti/lib/jiti-cli.mjs scripts/reset-admin-password.ts",
    "check:pg-rls": "node --env-file=.env ./node_modules/jiti/lib/jiti-cli.mjs scripts/check-pg-rls.ts",
    "check:pg-rls:fix": "node --env-file=.env ./node_modules/jiti/lib/jiti-cli.mjs scripts/check-pg-rls.ts --fix",
    "check:pg-rls:sql": "type .\\scripts\\sql\\payload-postgres-hardening.sql",
    "vercel:push-database-url": "node ./scripts/push-vercel-database-url.mjs",
    "test:pg": "node ./scripts/test-postgres-connection.mjs",
    "export:production-db": "node ./scripts/export-production-db.mjs --env-file .env.production.backup",
    "postgres:sql:catalog-tool-link": "node ./scripts/apply-postgres-sql-file.mjs scripts/sql/add-tool-suggestions-catalog-tool-id.sql"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@marsidev/react-turnstile": "^1.5.0",
    "@payloadcms/db-postgres": "^3.83.0",
    "@payloadcms/db-sqlite": "^3.83.0",
    "@payloadcms/next": "^3.83.0",
    "@payloadcms/richtext-lexical": "^3.83.0",
    "@payloadcms/storage-vercel-blob": "^3.83.0",
    "@payloadcms/ui": "^3.83.0",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.0",
    "graphql": "^16.13.2",
    "next": "^16.2.4",
    "nodemailer": "^8.0.5",
    "payload": "^3.83.0",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "jiti": "^2.6.1",
    "patch-package": "^8.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5"
  },
  "overrides": {
    "dompurify": "^3.4.0",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.11"
    }
  }
}
