# Copy to `.env` in the repo root before: docker compose up -d --build
#
# Migrating from Vercel + Supabase? See DEPLOY-DOCKER.md — copy PAYLOAD_SECRET,
# PREVIEW_SECRET, and Turnstile keys from Vercel → Settings → Environment Variables.
# Import the Supabase dump with: ./scripts/vps-import-database.sh

# --- Postgres (docker-compose `db` service) ---
POSTGRES_USER=opencatalog
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=opencatalog

# --- App secrets (use the SAME values as Vercel production when migrating) ---
PAYLOAD_SECRET=copy-from-vercel-payload-secret
PREVIEW_SECRET=copy-from-vercel-preview-secret

# --- Public URLs (must match how users reach the site; no trailing slash) ---
# First boot on a VPS IP only: http://203.0.113.10:3000
# Production domain:
NEXT_PUBLIC_SITE_URL=https://catalog.flossk.org
NEXT_PUBLIC_SERVER_URL=https://catalog.flossk.org
PAYLOAD_SERVER_URL=https://catalog.flossk.org

# --- Schema management ---
# false when importing a Supabase dump (recommended for Vercel migration)
# true only for a fresh empty Postgres + optional seed
PAYLOAD_POSTGRES_PUSH=false
PAYLOAD_SKIP_MIGRATION_PROMPT=true

# --- Caddy HTTPS profile (`docker compose --profile https up -d`) ---
SITE_DOMAIN=catalog.flossk.org

# --- Optional: only needed for fresh seed (not Supabase import) ---
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=changeme

# --- Cloudflare Turnstile (copy production pair from Vercel) ---
# NEXT_PUBLIC_TURNSTILE_SITE_KEY_PRODUCTION=0x4AAAAAA...
# TURNSTILE_SECRET_KEY_PRODUCTION=0x4AAAAAA...

# --- Optional: SMTP (or configure in Payload admin → General Settings) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_EMAIL=
# SMTP_FROM_NAME=

# --- Optional: VPS backups ---
# BACKUP_DIR=/var/backups/katalogu
# BACKUP_RETENTION_DAYS=31

# Do NOT set BLOB_READ_WRITE_TOKEN on VPS — media uses the media_data volume.
